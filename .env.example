# ============================================================================
# Gaia AI - Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ----- Core secrets -------------------------------------------------------
JWT_SECRET=replace-with-long-random-string-min-64-chars
JWT_ALG=HS256
JWT_EXPIRE_HOURS=168
AES_KEY=replace-with-32-byte-base64-key
BRIDGE_SECRET=replace-with-shared-hmac-secret-for-bridge-webhook

# ----- LLM provider API keys ----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Default model used by services/llm_provider.py
LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large

# ----- Postgres -----------------------------------------------------------
POSTGRES_USER=gaia
POSTGRES_PASSWORD=gaia_dev_password
POSTGRES_DB=gaia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gaia:gaia_dev_password@postgres:5432/gaia

# ----- MongoDB ------------------------------------------------------------
MONGO_URI=mongodb://mongo:27017
MONGO_DB=gaia

# ----- Qdrant -------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ----- Redis --------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- WhatsApp bridge ----------------------------------------------------
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:4000
BRIDGE_PORT=4000
# Backend URL the bridge calls back to (use service name in docker network)
BACKEND_INTERNAL_URL=http://backend:8000

# ----- Frontend -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ----- ML / Training ------------------------------------------------------
HF_TOKEN=
WANDB_API_KEY=
WANDB_PROJECT=gaia-ai
BASE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ----- Misc ---------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
