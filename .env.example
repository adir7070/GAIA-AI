# ============================================================================
# Gaia AI - Environment Variables (template)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ============================================================================

# ----- Core secrets -------------------------------------------------------
# Generate with:
#   openssl rand -hex 32      # for JWT_SECRET / BRIDGE_SECRET
#   openssl rand -base64 32   # for AES_KEY
JWT_SECRET=replace-with-long-random-string-min-64-chars
JWT_ALG=HS256
JWT_EXPIRE_HOURS=168
AES_KEY=replace-with-32-byte-base64-key
BRIDGE_SECRET=replace-with-shared-hmac-secret-for-bridge-webhook

# ----- LLM provider --------------------------------------------------------
# Pick ONE provider as the default and fill the matching key below.
# Free option: groq (recommended). Paid: anthropic, openai.
LLM_PROVIDER=groq

# Groq (free, very fast). Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Anthropic (paid). Optional - useful as a SECOND provider for the eval judge.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (paid). Optional - useful as a SECOND provider for the eval judge,
# or for cloud embeddings (otherwise we use local BGE which is free).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large

# ----- Postgres -----------------------------------------------------------
POSTGRES_USER=gaia
POSTGRES_PASSWORD=gaia_dev_password
POSTGRES_DB=gaia
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gaia:gaia_dev_password@postgres:5432/gaia

# ----- MongoDB ------------------------------------------------------------
MONGO_URI=mongodb://mongo:27017
MONGO_DB=gaia

# ----- Qdrant -------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ----- Redis --------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- WhatsApp bridge ----------------------------------------------------
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:4000
BRIDGE_PORT=4000
BACKEND_INTERNAL_URL=http://backend:8000

# ----- Frontend -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ----- ML / Training ------------------------------------------------------
HF_TOKEN=
WANDB_API_KEY=
WANDB_PROJECT=gaia-ai
BASE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ----- Misc ---------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
